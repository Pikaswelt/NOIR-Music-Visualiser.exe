{
  "name": "visualiser-music",
  "productName": "NOIR Music Visualiser",
  "version": "2.0.0",
  "description": "A dark, audio-reactive Windows music visualiser with live system audio capture.",
  "author": "Pikaswelt",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "desktop": "npm run build && electron .",
    "build:exe": "npm run build && electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "vite": "^8.0.16"
  },
  "build": {
    "appId": "com.noir.musicvisualiser",
    "productName": "NOIR Music Visualiser",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "NOIR-Music-Visualiser-${version}-portable.${ext}"
    }
  }
}
